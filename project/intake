#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
ROOT_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)

fail() {
    echo "ERROR: $*" >&2
    exit 1
}

resolve_python() {
    if [ -n "${PROJECT_INTAKE_PYTHON:-}" ]; then
        [ -x "$PROJECT_INTAKE_PYTHON" ] || fail "PROJECT_INTAKE_PYTHON is not executable: $PROJECT_INTAKE_PYTHON"
        printf '%s\n' "$PROJECT_INTAKE_PYTHON"
        return 0
    fi

    if [ -n "${VIRTUAL_ENV:-}" ]; then
        candidate="$VIRTUAL_ENV/bin/python"
        [ -x "$candidate" ] || fail "Active virtualenv has no python interpreter at $candidate"
        printf '%s\n' "$candidate"
        return 0
    fi

    candidate="$ROOT_DIR/.venv/bin/python"
    if [ -x "$candidate" ]; then
        printf '%s\n' "$candidate"
        return 0
    fi

    fail "No usable Python interpreter found. Activate a virtualenv with the product installed, set PROJECT_INTAKE_PYTHON explicitly, or create the compatibility env at $ROOT_DIR/.venv"
}

PYTHON=$(resolve_python)

usage() {
    cat <<'EOF'
Usage:
  project/intake init <workspace> [--object-id OBJECT_ID]
  project/intake generate <workspace> [--date YYYY-MM-DD] [--preserve-responses]
  project/intake compile <workspace> [--date YYYY-MM-DD]
  project/intake preview <workspace> [--date YYYY-MM-DD]
  project/intake review <workspace> [--date YYYY-MM-DD]
  project/intake evidence <workspace> [--date YYYY-MM-DD]
  project/intake verify [pytest args...]
  project/intake demo happy [--date YYYY-MM-DD]
  project/intake demo stress [--date YYYY-MM-DD]

Notes:
  - The wrapper prefers PROJECT_INTAKE_PYTHON, then the active VIRTUAL_ENV, and only then falls back to the repository's .venv/bin/python.
  - Canonical execution goes through installed modules under network_methodology_sandbox, not project/src paths.
  - `demo` replays checked-in exemplars in a temporary copy and does not edit the repo.
  - `generate --preserve-responses` reuses existing E/F/G/H workbook cells by field_id.
EOF
}

require_python() {
    if ! "$PYTHON" -c "import importlib.util, sys; sys.exit(0 if importlib.util.find_spec('network_methodology_sandbox.intake.init_workspace') and importlib.util.find_spec('network_methodology_sandbox.run_pipeline') else 1)" >/dev/null 2>&1; then
        fail "Python interpreter $PYTHON does not have the product installed. Activate a virtualenv and run: pip install -e './project[dev]'. The repo-local fallback env remains tracked in project/docs/plans/PLAN_APP_DEPENDENCY_DECOUPLING.md"
    fi
}

resolve_path() {
    case "$1" in
        /*) printf '%s\n' "$1" ;;
        *) printf '%s/%s\n' "$(pwd)" "$1" ;;
    esac
}

run_generate() {
    [ $# -ge 1 ] || fail "generate requires <workspace>"
    workspace=$(resolve_path "$1")
    shift
    "$PYTHON" -m network_methodology_sandbox.intake.generate_intake_sheets "$workspace" "$@"
}

run_init() {
    [ $# -ge 1 ] || fail "init requires <workspace>"
    workspace=$(resolve_path "$1")
    shift
    "$PYTHON" -m network_methodology_sandbox.intake.init_workspace "$workspace" "$@"
}

run_compile() {
    [ $# -ge 1 ] || fail "compile requires <workspace>"
    workspace=$(resolve_path "$1")
    shift
    "$PYTHON" -m network_methodology_sandbox.intake.compile_intake "$workspace" "$@"
}

run_preview() {
    [ $# -ge 1 ] || fail "preview requires <workspace>"
    workspace=$(resolve_path "$1")
    shift
    "$PYTHON" -m network_methodology_sandbox.intake.preview_status "$workspace" "$@"
}

run_review() {
    [ $# -ge 1 ] || fail "review requires <workspace>"
    workspace=$(resolve_path "$1")
    shift
    "$PYTHON" -m network_methodology_sandbox.intake.review_packets "$workspace" "$@"
}

run_evidence() {
    [ $# -ge 1 ] || fail "evidence requires <workspace>"
    workspace=$(resolve_path "$1")
    shift
    "$PYTHON" -m network_methodology_sandbox.intake.evidence_status "$workspace" "$@"
}

run_verify() {
    "$PYTHON" -m pytest "$ROOT_DIR/project/tests" -q "$@"
}

run_demo() {
    [ $# -ge 1 ] || fail "demo requires 'happy' or 'stress'"
    demo_name=$1
    shift

    demo_date=2026-04-02
    while [ $# -gt 0 ]; do
        case "$1" in
            --date)
                [ $# -ge 2 ] || fail "demo --date requires YYYY-MM-DD"
                demo_date=$2
                shift 2
                ;;
            *)
                fail "Unknown demo option: $1"
                ;;
        esac
    done

    case "$demo_name" in
        happy) exemplar_dir="$ROOT_DIR/project/examples/sample_object_01" ;;
        stress) exemplar_dir="$ROOT_DIR/project/examples/sample_object_02" ;;
        *) fail "demo target must be 'happy' or 'stress'" ;;
    esac

    tmp_dir=$(mktemp -d "${TMPDIR:-/tmp}/intake-demo.XXXXXX")
    trap 'rm -rf "$tmp_dir"' EXIT HUP INT TERM
    workspace="$tmp_dir/$(basename "$exemplar_dir")"
    cp -R "$exemplar_dir" "$workspace"

    "$PYTHON" -m network_methodology_sandbox.intake.compile_intake "$workspace" --date "$demo_date"

    if "$PYTHON" -m network_methodology_sandbox.run_pipeline "$workspace/questionnaire.yaml"; then
        pipeline_rc=0
    else
        pipeline_rc=$?
    fi

    case "$demo_name" in
        happy)
            [ "$pipeline_rc" -eq 0 ] || fail "happy demo failed unexpectedly"
            echo "Happy-path demo completed successfully in $workspace"
            ;;
        stress)
            [ "$pipeline_rc" -eq 1 ] || fail "stress demo expected pipeline exit 1, got $pipeline_rc"
            echo "Stress demo produced the expected domain validation failure in $workspace"
            ;;
    esac
}

main() {
    [ $# -ge 1 ] || {
        usage >&2
        exit 1
    }

    require_python

    command=$1
    shift

    case "$command" in
        init) run_init "$@" ;;
        generate) run_generate "$@" ;;
        compile) run_compile "$@" ;;
        preview) run_preview "$@" ;;
        review) run_review "$@" ;;
        evidence) run_evidence "$@" ;;
        verify) run_verify "$@" ;;
        demo) run_demo "$@" ;;
        -h|--help|help)
            usage
            ;;
        *)
            usage >&2
            fail "Unknown command: $command"
            ;;
    esac
}

main "$@"
